# OpenCloud configuration — copy to .env and fill in secrets. NEVER commit .env.
# Full variable reference: docs/INFRASTRUCTURE.md §3.

# --- Runtime ---
ENV=development
LOG_LEVEL=debug

# --- Go API ---
HTTP_ADDR=:8080
DATABASE_URL=postgres://opencloud:opencloud@localhost:5432/opencloud?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- Hosting node (Hestia) ---
# Leave as-is for local dev; the provisioner runs against a fake without a real node.
HESTIA_API_URL=https://hestia-node.example.com:8083
HESTIA_API_KEY=change-me

# --- HTTP hardening ---
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=10

# --- Frontend (server-side only, not NEXT_PUBLIC_) ---
API_URL=http://localhost:8080
